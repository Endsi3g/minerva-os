# Convex
CONVEX_DEPLOYMENT=dev:your-project
NEXT_PUBLIC_CONVEX_URL=https://xxx.convex.cloud

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to browser

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxx

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxx
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# AI
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxx

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx   # required — webhooks rejected if missing

# Media
NEXT_PUBLIC_BG_VIDEO_URL=https://assets.mixkit.co/videos/preview/mixkit-stars-in-space-background-1611-large.mp4

# CRM webhook (optional — set to require Authorization: Bearer <secret> on /api/crm/lead)
LEAD_WEBHOOK_SECRET=

# Demo mode — bypasses Supabase auth and DB calls, uses built-in mock data
# Set DEMO_MODE=true to run a fully functional demo without real credentials
# WARNING: never set this to true in a real production environment
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
