# ── Demo mode environment ──────────────────────────────────────────────────────
# Copy this file to .env.local to run a fully working demo without real credentials.
# All data is mock data. No Supabase, no Stripe, no AI key required.
#
# Usage:  cp .env.demo .env.local && npm run dev

DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Supabase placeholders — prevent throw on client init (no real DB calls made)
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=placeholder-anon-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Media
NEXT_PUBLIC_BG_VIDEO_URL=/Plan_fixe_cinématique_Anime_c.mp4

# Optional: add a real ANTHROPIC_API_KEY for live AI responses in demo mode
# ANTHROPIC_API_KEY=sk-ant-...
